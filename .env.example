# Mode Supabase (édition en ligne) : renseigner les deux variables ; sinon l’app utilise les JSON + APIs Vite locales.
# Projet Supabase → Settings → API : Project URL et anon public key.

# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optionnel : doit exister dans la table `seasons` (voir supabase/migrations/001_maika_schema.sql). Défaut : 2026
# VITE_SUPABASE_SEASON_ID=2026
